<!DOCTYPE html>
<html lang="pt-BR">

<body>
      <%- include("./partials/head") %>

      <header class="bg-primary superior d-flex flex-row p-3">
        <div class="flex-grow-1">
            <h1 class="fs-3"><i class="bi bi-list-ol"></i> Meu primeiro APP de Tarefas</h1>
        </div>
        <div class="flex-grow-1 d-flex flex-row-reverse">

            <button type="button btn-primary" class="btn">
                <h1 class="fs-3 px-3">
                    <i id="login" class="bi bi-person-circle"> login </i> 
                </h1>
            </button>
            
        </div>
    </header>

    <!--INICIO -  meio da pagina-->
    <main class="container d-flex flex-column">
        
        <!-- botoes de criacao e exclusao de tarefas -->
        <div class="d-flex gap-3 my-3">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal"><i class="bi bi-plus"></i> Nova Tarefa</button>
            <button type="button" class="btn btn-primary"><i class="bi bi-trash"></i> Excluir Tarefa</button>
        </div>

        <!--INICIO -  tabela de tarefas -->
        <table class="container table table-striped">
            <thead>
                <tr>
                    <th scope="col"></th>
                    <th scope="col">#</th>
                    <th scope="col">Dia</th>
                    <th scope="col">Hora</th>
                    <th scope="col">Descrição</th>
                    <th scope="col">Ações</th>
                </tr>
            </thead>
            <tbody>
                <% dados.forEach((tarefa, indice) => { %>
                    <!-- INICIO DE UMA TAREFA -->
                <tr>
                    <th scope="row"><input type="checkbox"></th>
                    <th scope="row"><%= indice + 1 %></th>
                    <td><%= new Date(tarefa.data).toLocaleDateString('pt-BR') %></td>
                    <td><%= tarefa.hora %></td>
                    <td><%= tarefa.descricao %></td>
                    <td>

                        <button type="button" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> 
                            Editar Tarefa
                        </button>

                    </td>
                </tr>
                <!-- FINAL DE UMA TAREFA -->
                <% }) %>
            </tbody>
        </table>
        <!--FINAL -  tabela de tarefas -->
        

    </main>
    <!--FIM -  meio da pagina-->

    <!--INICIO -  rodapé -->
    <footer>
        <div class="row">
            <div class="col-12 bg-primary py-3">
                <h1 class="titulo text-center fs-5 "><i class="bi bi-cc-circle"></i> Todos o direitos reservados</h1>
            </div>
        </div>

    </footer>
    <!--FINAL -  rodapé -->

    <!-- Inicio do Modal -->
    <div
      class="modal fade"
      id="exampleModal"
      tabindex="-1"
      aria-labelledby="exampleModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="exampleModalLabel">Tarefa</h1>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <form action="/cadastrar" method="POST">
            <div class="modal-body">
                <!-- inicio campos do formulario -->

                <!-- data da tarefa -->
                <div class="mb-3">
                <label for="dataTarefa" class="form-label">Data</label>
                <input
                    type="date"
                    class="form-control"
                    id="dataTarefa"
                    name="dataTarefa"
                />
                </div>

                <!-- hora da tarefa -->
                <div class="mb-3">
                <label for="horaTarefa" class="form-label">Hora</label>
                <input
                    type="time"
                    class="form-control"
                    id="horaTarefa"
                    name="horaTarefa"
                />
                </div>

                <!-- Descricao da tarefa  -->
                <div class="mb-3">
                <label for="descricaoTarefa" class="form-label">Descrição</label>
                <input
                    type="text"
                    class="form-control"
                    id="descricaoTarefa"
                    name="descricaoTarefa"
                />
                </div>

                <!-- final dos campos do formulario -->
            </div>
            <div class="modal-footer">
                <button
                type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal"
                >
                Close
                </button>
                <button id="btn-salvar" type="submit" class="btn btn-primary">
                Salvar Mudanças
                </button> 
            </div>
          </form>
        </div>
      </div>
    </div>
    <!-- Final do Modal -->
    

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>

    <script>
      //const modal = document.getElementById("exampleModal");
      const modal = new bootstrap.Modal(
        document.getElementById("exampleModal"),
      );

      const btnSalvar = document.getElementById("btn-salvar");

      btnSalvar.addEventListener("click", () => {
        modal.hide();
      });
    </script>
</body>

</html>